# Google OAuth Configuration
# Get these from: https://console.cloud.google.com/apis/credentials

# Web Client ID (for Expo Web and OAuth flow)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# iOS Client ID (for native iOS app)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Android Client ID (for native Android app)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual Google OAuth Client IDs
# 3. Restart the Expo server after making changes
# 4. See GOOGLE_OAUTH_SETUP.md for detailed setup instructions
