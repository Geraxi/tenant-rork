# Google OAuth Configuration
# Web Client ID (for Expo Web and OAuth flow)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=472863736917-bbcumr2di1lt92bgvlhuc6heuk4kiuok.apps.googleusercontent.com

# iOS Client ID (for native iOS app)
# You need to create this in Google Cloud Console for iOS
# Bundle ID: app.rork.tenant-app
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=472863736917-bbcumr2di1lt92bgvlhuc6heuk4kiuok.apps.googleusercontent.com

# Android Client ID (for native Android app)
# You need to create this in Google Cloud Console for Android
# Package name: app.rork.tenant-app
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=472863736917-bbcumr2di1lt92bgvlhuc6heuk4kiuok.apps.googleusercontent.com

# Note: The client ID you provided appears to be a Web client ID.
# For native mobile apps to work properly, you should create separate OAuth 2.0 credentials:
# 1. iOS OAuth client ID (with bundle ID: app.rork.tenant-app)
# 2. Android OAuth client ID (with package name: app.rork.tenant-app and SHA-1 certificate)
# 
# For now, I've set all three to use the same Web client ID, which will work for web
# but may have issues on native mobile. Please create the native credentials in:
# https://console.cloud.google.com/apis/credentials
